[
  {
    "_meta": true,
    "display_name": "Google Calendar",
    "description": "Calendar management: list, create, update, delete events, and manage Google Calendar"
  },
  {
    "name": "calendar_list_calendars",
    "description": "List all Google Calendars the user has access to.",
    "function": "calendarListCalendars",
    "parameters": {
      "properties": {},
      "required": []
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_list_events",
    "description": "List events from a Google Calendar within a time range.",
    "function": "calendarListEvents",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID (use 'primary' for the main calendar)"
        },
        "time_min": {
          "type": "string",
          "description": "Start of time range (ISO 8601 format, e.g., '2024-01-01T00:00:00Z')"
        },
        "time_max": {
          "type": "string",
          "description": "End of time range (ISO 8601 format)"
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum number of events (default: 20)"
        },
        "query": {
          "type": "string",
          "description": "Free text search query"
        }
      },
      "required": ["calendar_id"]
    },
    "timeoutSeconds": 30
  },
  {
    "name": "calendar_get_event",
    "description": "Get details of a specific Google Calendar event.",
    "function": "calendarGetEvent",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID"
        },
        "event_id": {
          "type": "string",
          "description": "Event ID"
        }
      },
      "required": ["calendar_id", "event_id"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_create_event",
    "description": "Create a new Google Calendar event.",
    "function": "calendarCreateEvent",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID (use 'primary' for the main calendar)"
        },
        "summary": {
          "type": "string",
          "description": "Event title"
        },
        "description": {
          "type": "string",
          "description": "Event description (optional)"
        },
        "location": {
          "type": "string",
          "description": "Event location (optional)"
        },
        "start": {
          "type": "string",
          "description": "Start time in ISO 8601 format (e.g., '2024-01-15T10:00:00-08:00')"
        },
        "end": {
          "type": "string",
          "description": "End time in ISO 8601 format"
        },
        "timezone": {
          "type": "string",
          "description": "Timezone (e.g., 'America/Los_Angeles')"
        },
        "attendees": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of attendee email addresses"
        },
        "all_day": {
          "type": "boolean",
          "description": "If true, create an all-day event (start/end should be dates like '2024-01-15')"
        }
      },
      "required": ["calendar_id", "summary", "start", "end"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_update_event",
    "description": "Update an existing Google Calendar event.",
    "function": "calendarUpdateEvent",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID"
        },
        "event_id": {
          "type": "string",
          "description": "Event ID to update"
        },
        "summary": {
          "type": "string",
          "description": "New event title (optional)"
        },
        "description": {
          "type": "string",
          "description": "New event description (optional)"
        },
        "location": {
          "type": "string",
          "description": "New event location (optional)"
        },
        "start": {
          "type": "string",
          "description": "New start time in ISO 8601 format (optional)"
        },
        "end": {
          "type": "string",
          "description": "New end time in ISO 8601 format (optional)"
        },
        "timezone": {
          "type": "string",
          "description": "Timezone (optional)"
        }
      },
      "required": ["calendar_id", "event_id"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_delete_event",
    "description": "Delete a Google Calendar event.",
    "function": "calendarDeleteEvent",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID"
        },
        "event_id": {
          "type": "string",
          "description": "Event ID to delete"
        }
      },
      "required": ["calendar_id", "event_id"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_search_events",
    "description": "Search for Google Calendar events by text query across the primary calendar.",
    "function": "calendarSearchEvents",
    "parameters": {
      "properties": {
        "query": {
          "type": "string",
          "description": "Free text search query"
        },
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID (default: 'primary')"
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum number of results (default: 20)"
        }
      },
      "required": ["query"]
    },
    "timeoutSeconds": 30
  },
  {
    "name": "calendar_quick_add",
    "description": "Quickly add a Google Calendar event using natural language (e.g., 'Meeting with John tomorrow at 3pm').",
    "function": "calendarQuickAdd",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID (use 'primary' for the main calendar)"
        },
        "text": {
          "type": "string",
          "description": "Natural language event description"
        }
      },
      "required": ["calendar_id", "text"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_get_freebusy",
    "description": "Query free/busy information for a set of calendars.",
    "function": "calendarGetFreeBusy",
    "parameters": {
      "properties": {
        "time_min": {
          "type": "string",
          "description": "Start of time range (ISO 8601 format)"
        },
        "time_max": {
          "type": "string",
          "description": "End of time range (ISO 8601 format)"
        },
        "calendar_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of calendar IDs to check (use 'primary' for main)"
        }
      },
      "required": ["time_min", "time_max", "calendar_ids"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_create_calendar",
    "description": "Create a new Google Calendar.",
    "function": "calendarCreateCalendar",
    "parameters": {
      "properties": {
        "summary": {
          "type": "string",
          "description": "Calendar name"
        },
        "description": {
          "type": "string",
          "description": "Calendar description (optional)"
        },
        "timezone": {
          "type": "string",
          "description": "Calendar timezone (e.g., 'America/New_York')"
        }
      },
      "required": ["summary"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "calendar_delete_calendar",
    "description": "Delete a Google Calendar (cannot delete primary calendar).",
    "function": "calendarDeleteCalendar",
    "parameters": {
      "properties": {
        "calendar_id": {
          "type": "string",
          "description": "Calendar ID to delete"
        }
      },
      "required": ["calendar_id"]
    },
    "timeoutSeconds": 15
  }
]
