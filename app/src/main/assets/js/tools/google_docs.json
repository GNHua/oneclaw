[
  {
    "_meta": true,
    "display_name": "Google Docs",
    "description": "Document editing: create, read, update, and format Google Docs documents"
  },
  {
    "name": "docs_get",
    "description": "Get the content and structure of a Google Docs document.",
    "function": "docsGet",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        }
      },
      "required": ["document_id"]
    },
    "timeoutSeconds": 30
  },
  {
    "name": "docs_create",
    "description": "Create a new Google Docs document.",
    "function": "docsCreate",
    "parameters": {
      "properties": {
        "title": {
          "type": "string",
          "description": "Document title"
        }
      },
      "required": ["title"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "docs_insert_text",
    "description": "Insert text at a specific location in a Google Docs document.",
    "function": "docsInsertText",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        },
        "text": {
          "type": "string",
          "description": "Text to insert"
        },
        "index": {
          "type": "integer",
          "description": "Character index where to insert the text (default: 1 for beginning)"
        }
      },
      "required": ["document_id", "text"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "docs_append_text",
    "description": "Append text to the end of a Google Docs document.",
    "function": "docsAppendText",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        },
        "text": {
          "type": "string",
          "description": "Text to append"
        }
      },
      "required": ["document_id", "text"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "docs_get_text",
    "description": "Extract plain text content from a Google Docs document.",
    "function": "docsGetText",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        }
      },
      "required": ["document_id"]
    },
    "timeoutSeconds": 30
  },
  {
    "name": "docs_batch_update",
    "description": "Apply a series of updates to a Google Docs document (advanced).",
    "function": "docsBatchUpdate",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        },
        "requests": {
          "type": "array",
          "description": "Array of update request objects (Google Docs API format)"
        }
      },
      "required": ["document_id", "requests"]
    },
    "timeoutSeconds": 30
  },
  {
    "name": "docs_delete_range",
    "description": "Delete a range of content from a Google Docs document by start and end index.",
    "function": "docsDeleteRange",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        },
        "start_index": {
          "type": "integer",
          "description": "Start character index of the range to delete"
        },
        "end_index": {
          "type": "integer",
          "description": "End character index of the range to delete"
        }
      },
      "required": ["document_id", "start_index", "end_index"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "docs_find_replace",
    "description": "Find and replace text in a Google Docs document.",
    "function": "docsFindReplace",
    "parameters": {
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Google Docs document ID"
        },
        "find_text": {
          "type": "string",
          "description": "Text to search for"
        },
        "replace_text": {
          "type": "string",
          "description": "Replacement text"
        },
        "match_case": {
          "type": "boolean",
          "description": "Whether to match case (default: false)"
        }
      },
      "required": ["document_id", "find_text", "replace_text"]
    },
    "timeoutSeconds": 15
  }
]
