[
  {
    "_meta": true,
    "display_name": "Google Forms",
    "description": "Form management: create forms, add questions, get responses, and manage Google Forms"
  },
  {
    "name": "forms_get",
    "description": "Get the structure and questions of a Google Form.",
    "function": "formsGet",
    "parameters": {
      "properties": {
        "form_id": {
          "type": "string",
          "description": "Google Forms form ID"
        }
      },
      "required": ["form_id"]
    },
    "timeoutSeconds": 15
  },
  {
    "name": "forms_list_responses",
    "description": "List responses to a Google Form.",
    "function": "formsListResponses",
    "parameters": {
      "properties": {
        "form_id": {
          "type": "string",
          "description": "Google Forms form ID"
        },
        "page_size": {
          "type": "integer",
          "description": "Maximum number of responses to return (default: 20)"
        },
        "page_token": {
          "type": "string",
          "description": "Page token for pagination (optional)"
        }
      },
      "required": ["form_id"]
    },
    "timeoutSeconds": 30
  },
  {
    "name": "forms_get_response",
    "description": "Get a specific response to a Google Form.",
    "function": "formsGetResponse",
    "parameters": {
      "properties": {
        "form_id": {
          "type": "string",
          "description": "Google Forms form ID"
        },
        "response_id": {
          "type": "string",
          "description": "Response ID"
        }
      },
      "required": ["form_id", "response_id"]
    },
    "timeoutSeconds": 15
  }
]
