  {
    "name": "tasks_list_tasks",
    "description": "List tasks in a Google Tasks task list.",
    "function": "tasksListTasks",
    "parameters": {
      "properties": {
        "tasklist_id": {
          "type": "string",
          "description": "Task list ID (use '@default' for the default list)"
        },
        "show_completed": {
          "type": "boolean",
          "description": "Include completed tasks (default: false)"
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum number of tasks to return (default: 20)"
        }
      },
      "required": ["tasklist_id"]
    },
    "timeoutSeconds": 15
  },
  {
